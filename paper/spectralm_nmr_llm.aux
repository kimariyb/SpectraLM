\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Candidate-generation bottleneck.} \textbf  {a}, Mean candidate counts through parsing, domain filtering, formula filtering, and reference-presence checks. Formula filtering removes most sampled structures; the correct reference appears in the selectable formula-conditioned set for only 0.5\% of test examples. \textbf  {b}, Practical implication: the present bottleneck is recall of formula-valid candidates, not the reranker.}}{9}{figure.3}\protected@file@percent }
\newlabel{fig:candidate-bottleneck}{{3}{9}{\textbf {Candidate-generation bottleneck.} \textbf {a}, Mean candidate counts through parsing, domain filtering, formula filtering, and reference-presence checks. Formula filtering removes most sampled structures; the correct reference appears in the selectable formula-conditioned set for only 0.5\% of test examples. \textbf {b}, Practical implication: the present bottleneck is recall of formula-valid candidates, not the reranker}{figure.3}{}}
